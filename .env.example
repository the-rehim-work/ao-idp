# External PostgreSQL
DB_HOST=your-postgres-host
DB_PORT=5432
DB_NAME=ao_idp
DB_USERNAME=ao_idp
DB_PASSWORD=change_me

# External Redis
REDIS_HOST=your-redis-host
REDIS_PORT=6379

# External LDAP / Active Directory
LDAP_URL=ldaps://ldap.ao.az:636
LDAP_BASE_DN=DC=ao,DC=az
LDAP_SERVICE_ACCOUNT_DN=CN=idp-svc,OU=ServiceAccounts,DC=ao,DC=az
LDAP_SERVICE_PASSWORD=change_me
LDAP_USERNAME_ATTR=sAMAccountName
LDAP_USER_OBJECT_CLASS=user

# IDP
IDP_ISSUER=https://auth.ao.az
COOKIE_DOMAIN=.ao.az
