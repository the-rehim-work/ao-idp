# Copy this file to .env and fill in the values before running docker compose up
# cp .env.example .env

DB_NAME=ao_idp
DB_USERNAME=ao_idp
DB_PASSWORD=changeme

# The public URL this IDP is reachable at (used in OIDC discovery & token issuer)
IDP_ISSUER=http://localhost:7000

# Domain for the session cookie (use localhost for local dev)
COOKIE_DOMAIN=localhost
